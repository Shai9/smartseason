<div class="card" style="max-width: 600px; margin: 0 auto;">
  <h1 style="font-size: 1.5rem; font-weight: bold; margin-bottom: 1.5rem;">Update Field: <%= @field.name %></h1>
  
  <%= form_with model: [@field, @update], local: true, class: "form" do |f| %>
    <div style="margin-bottom: 1rem;">
      <%= f.label :stage, style: "display: block; margin-bottom: 0.5rem; font-weight: 500;" %>
      <%= f.select :stage, Field.current_stages.keys.map { |s| [s.titleize, s] }, {}, 
          style: "width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem;" %>
    </div>
    
    <div style="margin-bottom: 1rem;">
      <%= f.label :notes, style: "display: block; margin-bottom: 0.5rem; font-weight: 500;" %>
      <%= f.text_area :notes, rows: 5, 
          style: "width: 100%; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem;",
          placeholder: "Add your observations, notes, or comments about this field..." %>
    </div>
    
    <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
      <%= f.submit "Save Update", class: "btn btn-primary", style: "cursor: pointer;" %>
      <%= link_to "Cancel", agent_dashboard_path, class: "btn btn-secondary", style: "text-decoration: none; text-align: center;" %>
    </div>
  <% end %>
  
  <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #e5e7eb;">
    <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem;">Field Information</h3>
    <p><strong>Crop:</strong> <%= @field.crop_type %></p>
    <p><strong>Current Stage:</strong> <%= @field.current_stage.titleize %></p>
    <p><strong>Planting Date:</strong> <%= @field.planting_date.strftime("%B %d, %Y") %></p>
    <p><strong>Status:</strong> 
      <span class="status-badge status-<%= @field.computed_status.downcase.gsub(' ', '-') %>">
        <%= @field.computed_status %>
      </span>
    </p>
  </div>
</div>

<style>
  .form input, .form select, .form textarea {
    font-family: inherit;
  }
  
  .btn {
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    text-decoration: none;
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 500;
  }
  
  .btn-primary {
    background: #16a34a;
    color: white;
    border: none;
  }
  
  .btn-primary:hover {
    background: #15803d;
    cursor: pointer;
  }
  
  .btn-secondary {
    background: #6b7280;
    color: white;
  }
  
  .btn-secondary:hover {
    background: #4b5563;
  }
  
  .status-badge {
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    display: inline-block;
  }
  
  .status-active {
    background: #dcfce7;
    color: #166534;
  }
  
  .status-at-risk {
    background: #fef3c7;
    color: #92400e;
  }
  
  .status-completed {
    background: #f3f4f6;
    color: #374151;
  }
</style>
EOF
