<div class="container" style="max-width: 400px; margin-top: 100px;">
  <div class="card">
    <div style="text-align: center; margin-bottom: 2rem;">
      <h1 style="font-size: 2rem; font-weight: 700; color: #16a34a; margin-bottom: 0.5rem;">SmartSeason</h1>
      <p style="color: #6b7280;">Field Monitoring System</p>
    </div>
    
    <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1rem;">Sign in to your account</h2>
    
    <%= form_with url: login_path, local: true, class: "form" do |f| %>
      <div style="margin-bottom: 1rem;">
        <%= f.email_field :email, required: true, 
            style: "width: 100%; padding: 0.75rem; border: 1px solid #d1d5db; border-radius: 0.375rem; font-family: 'Bricolage Grotesque', sans-serif;",
            placeholder: "Email address" %>
      </div>
      
      <div style="margin-bottom: 1.5rem;">
        <%= f.password_field :password, required: true,
            style: "width: 100%; padding: 0.75rem; border: 1px solid #d1d5db; border-radius: 0.375rem; font-family: 'Bricolage Grotesque', sans-serif;",
            placeholder: "Password" %>
      </div>
      
      <div>
        <%= f.submit "Sign in", class: "btn btn-primary", style: "width: 100%; cursor: pointer; font-weight: 600; padding: 0.75rem;" %>
      </div>
    <% end %>
    
    <div style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #e5e7eb;">
      <p style="font-size: 0.875rem; color: #6b7280; margin-bottom: 0.5rem;"><strong>Demo Credentials:</strong></p>
      <p style="font-size: 0.875rem; color: #6b7280;">Admin: admin@smartseason.com / admin123</p>
      <p style="font-size: 0.875rem; color: #6b7280;">Agent: smartagent@smartseason.com / agent123</p>
    </div>
  </div>
</div>
